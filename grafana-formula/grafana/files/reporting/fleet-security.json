            "uid": "{{ datasource_uid }}"
          },
          "rawSql": "SELECT bucket AS checkin_age, cnt AS systems FROM ( SELECT CASE WHEN last_checkin_time >= NOW() - INTERVAL '1 day' THEN '1 - Last 24h' WHEN last_checkin_time >= NOW() - INTERVAL '7 days' THEN '2 - 1-7 days' WHEN last_checkin_time >= NOW() - INTERVAL '30 days' THEN '3 - 7-30 days' WHEN last_checkin_time >= NOW() - INTERVAL '90 days' THEN '4 - 30-90 days' ELSE '5 - 90+ days' END AS bucket, COUNT(*) AS cnt FROM System WHERE organization IN ($organization) AND (NOT EXISTS (SELECT 1 FROM System WHERE is_proxy AND hostname NOT IN ($proxy_name)) OR proxy_system_id IN (SELECT system_id FROM System WHERE is_proxy AND hostname IN ($proxy_name))) AND (NOT EXISTS (SELECT 1 FROM SystemGroup WHERE name NOT IN ($system_group)) OR system_id IN (SELECT sgm.system_id FROM SystemGroupMember sgm WHERE sgm.group_name IN ($system_group))) GROUP BY bucket ) sub ORDER BY bucket",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        },
        "sortBy": []
      }
