    {
      "id": 30,
      "title": "System Currency Score (Patch Risk Ranking)",
      "description": "Weighted patch risk score per system. Higher score = more patches needed. Weight: critical=32, important=16, moderate=8, low=4, bugfix=2, enhancement=1. Based on the legacy system-currency report.",
      "type": "table",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "{{ datasource_uid }}"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "{{ datasource_uid }}"
          },
          "rawSql": "SELECT s.hostname, s.system_id, s.organization, COUNT(CASE WHEN e.advisory_type = 'Security Advisory' AND e.severity = 'critical' THEN 1 END) AS critical, COUNT(CASE WHEN e.advisory_type = 'Security Advisory' AND e.severity = 'important' THEN 1 END) AS important, COUNT(CASE WHEN e.advisory_type = 'Security Advisory' AND e.severity = 'moderate' THEN 1 END) AS moderate, COUNT(CASE WHEN e.advisory_type = 'Security Advisory' AND (e.severity = 'low' OR e.severity IS NULL) THEN 1 END) AS low, COUNT(CASE WHEN e.advisory_type = 'Bug Fix Advisory' THEN 1 END) AS bugfix, COUNT(CASE WHEN e.advisory_type = 'Product Enhancement Advisory' THEN 1 END) AS enhancement, (COUNT(CASE WHEN e.advisory_type = 'Security Advisory' AND e.severity = 'critical' THEN 1 END) * 32 + COUNT(CASE WHEN e.advisory_type = 'Security Advisory' AND e.severity = 'important' THEN 1 END) * 16 + COUNT(CASE WHEN e.advisory_type = 'Security Advisory' AND e.severity = 'moderate' THEN 1 END) * 8 + COUNT(CASE WHEN e.advisory_type = 'Security Advisory' AND (e.severity = 'low' OR e.severity IS NULL) THEN 1 END) * 4 + COUNT(CASE WHEN e.advisory_type = 'Bug Fix Advisory' THEN 1 END) * 2 + COUNT(CASE WHEN e.advisory_type = 'Product Enhancement Advisory' THEN 1 END)) AS score FROM SystemErrata se JOIN System s ON se.mgm_id = s.mgm_id AND se.system_id = s.system_id JOIN Errata e ON se.mgm_id = e.mgm_id AND se.errata_id = e.errata_id WHERE s.organization IN ($organization) AND (NOT EXISTS (SELECT 1 FROM System WHERE is_proxy AND hostname NOT IN ($proxy_name)) OR s.proxy_system_id IN (SELECT system_id FROM System WHERE is_proxy AND hostname IN ($proxy_name))) AND (NOT EXISTS (SELECT 1 FROM SystemGroup WHERE name NOT IN ($system_group)) OR s.system_id IN (SELECT sgm.system_id FROM SystemGroupMember sgm WHERE sgm.group_name IN ($system_group))) GROUP BY s.hostname, s.system_id, s.organization ORDER BY score DESC LIMIT 100",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "critical"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "important"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "score"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-reds"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "hostname"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View system in Uyuni",
                    "url": "https://{{ server }}/rhn/systems/details/Overview.do?sid=${__data.fields.system_id}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
