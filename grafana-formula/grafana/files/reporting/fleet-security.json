        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "{{ datasource_uid }}"
          },
          "rawSql": "SELECT CASE WHEN svd.virtual_system_id IS NOT NULL THEN 'Virtual' ELSE 'Physical' END AS type, COUNT(*) AS count FROM System s LEFT JOIN SystemVirtualData svd ON s.mgm_id = svd.mgm_id AND s.system_id = svd.virtual_system_id WHERE s.organization IN ($organization) AND (NOT EXISTS (SELECT 1 FROM System WHERE is_proxy AND hostname NOT IN ($proxy_name)) OR s.proxy_system_id IN (SELECT system_id FROM System WHERE is_proxy AND hostname IN ($proxy_name))) AND (NOT EXISTS (SELECT 1 FROM SystemGroup WHERE name NOT IN ($system_group)) OR s.system_id IN (SELECT sgm.system_id FROM SystemGroupMember sgm WHERE sgm.group_name IN ($system_group))) GROUP BY type ORDER BY count DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
