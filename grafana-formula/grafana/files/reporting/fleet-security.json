          "rawSql": "SELECT DISTINCT s.hostname, s.system_id, s.architecture, s.minion_os_family AS os_family, na.address AS ip_address, e.advisory_name, e.severity, e.cve FROM SystemErrata se JOIN System s ON se.mgm_id = s.mgm_id AND se.system_id = s.system_id JOIN Errata e ON se.mgm_id = e.mgm_id AND se.errata_id = e.errata_id LEFT JOIN SystemNetInterface ni ON s.mgm_id = ni.mgm_id AND s.system_id = ni.system_id AND ni.primary_interface LEFT JOIN SystemNetAddressV4 na ON s.mgm_id = na.mgm_id AND s.system_id = na.system_id AND ni.interface_id = na.interface_id WHERE e.advisory_type = 'Security Advisory' AND e.cve IS NOT NULL AND s.organization IN ($organization) AND (NOT EXISTS (SELECT 1 FROM System WHERE is_proxy AND hostname NOT IN ($proxy_name)) OR s.proxy_system_id IN (SELECT system_id FROM System WHERE is_proxy AND hostname IN ($proxy_name))) AND (NOT EXISTS (SELECT 1 FROM SystemGroup WHERE name NOT IN ($system_group)) OR s.system_id IN (SELECT sgm.system_id FROM SystemGroupMember sgm WHERE sgm.group_name IN ($system_group))) ORDER BY s.hostname LIMIT 500",
