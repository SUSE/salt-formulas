                "uid": "{{ datasource_uid }}"
              },
              "rawSql": "SELECT s.hostname, spi.name AS package_name, spi.epoch, spi.version, spi.release, spi.arch FROM SystemPackageInstalled spi JOIN System s ON spi.mgm_id = s.mgm_id AND spi.system_id = s.system_id WHERE s.organization IN ($organization) AND (NOT EXISTS (SELECT 1 FROM System WHERE is_proxy AND hostname NOT IN ($proxy_name)) OR s.proxy_system_id IN (SELECT system_id FROM System WHERE is_proxy AND hostname IN ($proxy_name))) AND (NOT EXISTS (SELECT 1 FROM SystemGroup WHERE name NOT IN ($system_group)) OR s.system_id IN (SELECT sgm.system_id FROM SystemGroupMember sgm WHERE sgm.group_name IN ($system_group))) ORDER BY s.hostname, spi.name LIMIT 500",
              "format": "table",
              "refId": "A"
            }
